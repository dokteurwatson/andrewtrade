# Comma-separated or JSON array is supported by loader.
# Default set requested: BTC, ETH, XRP
COIN_LIST=["BTC","ETH","XRP"]

# For current monitoring set including DOGE, override in runtime env:
# COIN_LIST=["BTC","ETH","XRP","DOGE"]

# Risk policy requested:
# - Below threshold balance: all-in position sizing (full wallet)
# - At/above threshold balance: normal risk limits
RISK_THRESHOLD_BALANCE=100
POSITION_SIZING_BELOW_THRESHOLD=all_in
RISK_PER_TRADE_ABOVE_THRESHOLD=0.01
MAX_DAILY_LOSS_ABOVE_THRESHOLD=0.03
MAX_OPEN_POSITIONS_ABOVE_THRESHOLD=1

# Runtime settings
MODE=paper
EXCHANGE_ID=kraken
TIMEFRAME=4h
POLL_SECONDS=60
CANDLE_LIMIT=300
PAPER_START_CAPITAL_USD=50
MIN_ORDER_USD=10

# Costs (Kraken-like defaults, can be adjusted)
SLIPPAGE_RATE=0.0005
TAKER_FEE_RATE=0.0026

# Strategy parameters
RSI_PERIOD=2
RSI_ENTRY_THRESHOLD=20
RSI_EXIT_THRESHOLD=70
SMA_PERIOD=200
STOP_LOSS_PCT_ABOVE_THRESHOLD=0.02
MAX_CONSECUTIVE_LOSSES_ABOVE_THRESHOLD=3
COOLDOWN_CANDLES_AFTER_LIMIT=3

# Telegram alerts per trade
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Persisted paper state/trade logs
STATE_DIR=./state

# Logging mode: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Meme KPI for profitable exits
BUGATTI_TARGET_USD=2000000
