# ============================================================
# Stock Trader — .env configuratie
# Kopieer naar .env en vul de juiste waarden in.
# ============================================================

# --- Kapitaal (paper-mode) ---
PAPER_CAPITAL=1000.0

# ============================================================
# MARKTDATA (1m bars voor signalen)
# ============================================================
# finazon  = SIP real-time, 100% US marktdekking ($19/mnd non-pro) ← aanbevolen
# alpaca   = IEX real-time via gratis paper-account (~3% volume)
# polygon  = SIP/IEX, betaald (Starter=$29 15min delay, Developer=$79 IEX)
# yfinance = gratis, ~15 min vertraging (alleen backtest / DATA_SOURCE=yfinance dev)
# Dashboard live-quotes volgen DATA_SOURCE (finazon = zelfde bars als signalen)
DATA_SOURCE=finazon

# -- Finazon (DATA_SOURCE=finazon) --
# Aanmelden: finazon.io → kies 'US Equities Basic' dataset (~$19/mnd non-pro)
FINAZON_API_KEY=

# -- Alpaca Market Data (DATA_SOURCE=alpaca) --
# Maak gratis paper-account op alpaca.markets → Settings → API Keys
ALPACA_API_KEY=
ALPACA_API_SECRET=
# iex = gratis real-time (paper account) | sip = volledig ($99/mnd)
ALPACA_DATA_FEED=iex

# -- Polygon (DATA_SOURCE=polygon, optioneel) --
POLYGON_API_KEY=

# Polling interval voor yfinance/polygon (seconden); Finazon/Alpaca gebruikt WebSocket
BAR_POLL_SECONDS=60

# ============================================================
# BROKER (order uitvoering)
# ============================================================
# t212   = Trading 212 (Invest/ISA, US equities) ← aanbevolen
# paper  = volledig gesimuleerd (geen echte orders)
BROKER=t212

# -- Trading 212 (BROKER=t212) --
# Genereer API-sleutelpaar in de T212 app: Profiel → API (beta)
T212_API_KEY=
T212_API_SECRET=
# true  → demo.trading212.com (geen echt geld) — start hier!
# false → live.trading212.com (echt geld)
T212_DEMO=true

# FX fallback (live EURUSD=X / GBPUSD=X wordt gebruikt; env alleen bij fetch-fout)
FX_EUR_USD=1.08
FX_GBP_USD=1.27
# Extra marge op FX-schatting vóór order (T212 spread/fees; default 3%)
FX_BUFFER_PCT=0.03

# ============================================================
# STRATEGIE
# ============================================================
# Volume-multiplier: breakout candle volume moet >= VOLUME_MULT × ORB-gemiddelde
VOLUME_MULT=2.0

# Opening Range Breakout filter
#   0  = Scenario A — alleen volume-check, geen prijsfilter (snelste, meeste trades)
#   5  = Scenario B — ook prijs boven 5m high vereist
#   15 = Scenario C — ook prijs boven 15m high vereist (strengste, hoogste kwaliteit)
ORB_MINUTES=0

# ============================================================
# ORDERLIMIETEN & RISICOBEHEER
# ============================================================
MAX_ORDER_USD=500
MAX_SHARES_PER_ORDER=0
CASH_RESERVE_PCT=0.02
RISK_THRESHOLD_USD=200
RISK_PER_TRADE_PCT=0.02
MAX_POSITION_PCT=0.25
MAX_POSITION_PCT_LARGE=0.10
LARGE_CAP_THRESHOLD=10000
MAX_POSITIONS=3

# ============================================================
# TELEGRAM (optioneel)
# ============================================================
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================================
# DASHBOARD & SYSTEEM
# ============================================================
AUTO_RESUME_TRADING=true
DASHBOARD_PORT=5001
STATE_DIR=./stocktrader_state
LOG_LEVEL=INFO
