# Stock Trader — Krush watchlist strategie
# Kopieer naar .env en vul in

# --- Modus ---
# true  = paper trading (geen IBKR nodig, simuleert orders intern)
# false = orders via IBKR Gateway (paper poort 4002 of live 4001)
PAPER_MODE=true
PAPER_CAPITAL=1000.0       # alleen nodig als TRACKED_CAPITAL=true of PAPER_MODE=true

# --- Profiel A: kleine IBKR paper wallet (~50 EUR/USD na account-reset) ---
# Zet in Gateway je paper-saldo op ~50; dan sizing = echt IB-saldo, geen trucs nodig:
#   PAPER_MODE=false
#   TRACKED_CAPITAL=false
#   MAX_ORDER_USD=0
#   MAX_ORDER_SHARES=500   # alleen als IB app per order max 500 blijft eisen bij verkopen

# --- Profiel B: grote IBKR paper wallet ($1M) — eigen boekhouding ---
#   TRACKED_CAPITAL=true
#   PAPER_CAPITAL=1000
#   MAX_ORDER_USD=500

TRACKED_CAPITAL=false
MAX_ORDER_USD=0
MAX_SHARES_PER_ORDER=0
MAX_ORDER_SHARES=500

# --- Data bron (alleen voor paper mode) ---
# yfinance = Yahoo Finance (gratis, ~15min vertraging)
# polygon  = Polygon.io (real-time, gratis tier 15 req/min)
DATA_SOURCE=yfinance
POLYGON_API_KEY=           # verplicht als DATA_SOURCE=polygon

# --- IBKR Gateway verbinding (alleen als PAPER_MODE=false) ---
# IB Gateway moet draaien (paper poort 4002, live poort 4001)
# In Docker/k3s: IBKR_HOST=ib-gateway (naam van de Gateway container/service)
IBKR_HOST=ib-gateway
IBKR_PORT=4002             # 4002 = paper, 4001 = live
IBKR_CLIENT_ID=1
# OTC-filter: true = skip OTC/PINK primary listing | false = alles wat IBKR kent
OTC_FILTER_ENABLED=true
# Market data: delayed = gratis ~15min (geen Error 420) | live = betaald abonnement
IBKR_MARKET_DATA_TYPE=delayed
# historical = 1m bars via keepUpToDate (aanbevolen) | realtime = reqRealTimeBars
IBKR_BAR_STREAM=historical

# --- Strategie ---
VOLUME_MULT=2.0            # breakout candle >= 2x ORB gemiddeld volume
ORB_MINUTES=0              # 0 = geen ORB filter, 5 of 15 voor stricter
STOP_LOSS_FIELD=hold
TARGET_FIELD=t1

# --- Kapitaal & risicobeheer ---
CASH_RESERVE_PCT=0.02      # 2% cash buffer (fees)
RISK_THRESHOLD_USD=200     # onder dit bedrag: all-in | erboven: risico-based
RISK_PER_TRADE_PCT=0.02    # 2% van portfolio per trade riskeren
MAX_POSITION_PCT=0.25      # max positiegrootte als % van portfolio (onder LARGE_CAP_THRESHOLD)
MAX_POSITION_PCT_LARGE=0.10  # max positiegrootte boven LARGE_CAP_THRESHOLD (bv. $10k)
LARGE_CAP_THRESHOLD=10000    # boven dit bedrag → MAX_POSITION_PCT_LARGE gebruiken
MAX_POSITIONS=3            # max gelijktijdige open posities

# --- Telegram ---
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Server ---
DASHBOARD_PORT=5001
STATE_DIR=./stocktrader_state
LOG_LEVEL=INFO
